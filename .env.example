# ---- Nowlez Munshi (this app) ----
DEV_MODE=1                                       # enables POST /auth/dev-login; set 0 in prod
MUNSHI_DATABASE_URL=sqlite:///./nowlez_munshi.db # OUR engine (own SQLite for the prototype)

# ---- Shared identity (read by the `identity` package) ----
# Must be identical wherever Nowlez Munshi tokens are minted/verified.
JWT_SECRET_KEY=change-me-in-prod
# JWT_ACCESS_TTL_MINUTES=30

# ---- Munshi brain (Gemini) ----
# Leave GEMINI_API_KEY unset to run the deterministic OFFLINE answer path
# (fully functional + how the tests run). Set it to use the real model.
# GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# ---- Real WhatsApp/SMS OTP delivery (OPTIONAL; not needed for the demo) ----
# Needed only for the real /auth/start + /auth/verify path; the demo uses
# /auth/dev-login which skips delivery entirely.
# META_ACCESS_TOKEN=
# META_PHONE_NUMBER_ID=
# MSG91_AUTH_KEY=

# NOTE: do NOT set DATABASE_URL. The shared data_access package keeps its
# (unused) default engine; this app runs its own MUNSHI_DATABASE_URL engine and
# passes sessions into the shared DAOs.
