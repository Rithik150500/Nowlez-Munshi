# ---- Core ----
DEV_MODE=1                                  # enables /auth/dev-login; MUST be 0 in prod
# ENV=production                            # set in prod → activates the safety hard-fails
DATABASE_URL=sqlite:///./dev.db             # prod: postgresql+psycopg2://user:pass@host/db
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=change-me-in-prod            # prod: a strong >=32-byte secret (hard-fail otherwise)

# ---- AI Munshi (Gemini) ----
# Unset → deterministic OFFLINE agent (how the tests + a credless demo run).
# GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# ---- eCourts ----
ECOURTS_OFFLINE=1                           # 1 = synthetic cases (dev/tests); 0 = live portal (prod)

# ---- WhatsApp / Meta (optional; the demo uses dev-login + offline) ----
# META_ACCESS_TOKEN=
# META_PHONE_NUMBER_ID=
# META_VERIFY_TOKEN=          # webhook subscribe handshake
# META_APP_SECRET=            # webhook X-Hub-Signature-256 verification
# MSG91_AUTH_KEY=             # SMS OTP fallback
# MSG91_OTP_TEMPLATE_ID=

# ---- Continuity / web ----
# WEB_BASE_URL=https://app.nowlez.in        # enables WhatsApp→web deep-links

# ---- Documents (OnlyOffice; optional) ----
# ONLYOFFICE_SERVER_URL=http://localhost:8081
# ONLYOFFICE_JWT_SECRET=

# ---- Observability (optional) ----
# SENTRY_DSN=
# ALERT_WEBHOOK_URL=
